# 原始资料（本地真实数据，包括四普档案 DOCX、Shapefile、DEM、3D 模型等，
# 一律不纳入 Git。仓库自带的公开演示数据位于 data/output/，可随仓库发布）
data/input/

# 运行时产物 / 大文件缓存（保留 data/output/ 下公开 demo 数据的子目录，
# 但把下面几类可能含敏感或体积很大的运行产物单独 ignore）
data/output/tile_cache/
data/output/worklog_pdf/
data/output/worklog_pdfs/
data/output/3dtiles/
data/output/models_3d/
data/output/dem/
*.log

# 用户配置（含敏感信息）
config.yaml
.env
.env.*
*.key

# 便携版 Python
python/
.venv/

# Python 缓存
__pycache__/
.pytest_cache/
*.pyc
*.pyo
*.pyd

# IDE
.vscode/
.idea/

# 操作系统
Thumbs.db
.DS_Store
desktop.ini

# Node.js (前端工程通用)
node_modules/
.npm-cache/
*.tsbuildinfo

# Vite / 构建产物 (Vue 后台、React 主前端)
platform/admin-vue/dist/
platform/webgis-react/dist/

# Vite cache
.vite/
.vite_cache/
